# ─── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API key — get one free at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Recommended ───────────────────────────────────────────────────────────────

# Secret for securing the /api/refresh cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# Password for the /admin dashboard
# Generate with: openssl rand -hex 16
ADMIN_SECRET=your_admin_secret_here

# ─── Auto-set by Vercel KV ─────────────────────────────────────────────────────
# These are populated automatically when you link a Vercel KV store.
# For local development: run `vercel env pull` after linking KV.

KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
